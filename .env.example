# ─────────────────────────────────────────────
# Invoice App — пример .env
# Скопируйте в .env и заполните реальными значениями
# ─────────────────────────────────────────────

# ─── База данных (Neon Postgres через Vercel Marketplace) ───
DATABASE_URL="postgresql://user:pass@host.neon.tech/dbname?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host.neon.tech/dbname?sslmode=require"

# ─── Auth.js ───
# Сгенерировать: npx auth secret
AUTH_SECRET=""
# URL приложения (на Vercel заполнится автоматически)
AUTH_URL="http://localhost:3000"

# ─── Redis (Upstash через Vercel Marketplace) ───
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Vercel Blob (хранение PDF и логотипов) ───
BLOB_READ_WRITE_TOKEN=""

# ─── Wise API (курсы валют THB→USD) ───
# Получить: https://wise.com/settings/api-tokens
WISE_API_TOKEN=""
WISE_API_BASE_URL="https://api.wise.com"

# ─── Super-admin (первый пользователь, создаётся при seed) ───
SUPER_ADMIN_EMAIL="admin@ibgproperty.com"
SUPER_ADMIN_PASSWORD="change-me-on-first-login"
